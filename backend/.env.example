# Backend Configuration
NODE_ENV=development
PORT=3000

# Database Configuration
DB_HOST=postgres
DB_PORT=5432
DB_NAME=content_generator
DB_USER=postgres
DB_PASSWORD=SUPERCRET
DATABASE_URL=postgresql://postgres:SUPERCRET@localhost:5432/content_generator

# JWT Configuration
JWT_SECRET=SUPERCRET
JWT_EXPIRES_IN=24h

# OpenAI Configuration
OPENAI_API_KEY=sk-CHANGE_ME_IN_PRODUCTION
OPENAI_MODEL=gpt-3.5-turbo

# WordPress Configuration
WORDPRESS_DB_NAME=wordpress
WORDPRESS_DB_USER=wordpress
WORDPRESS_DB_PASSWORD=SUPERCRET
WORDPRESS_URL=http://localhost:8080
WORDPRESS_PLUGIN_ENDPOINT=/wp-json/content-generator/v1/receive-post
WORDPRESS_WEBHOOK_SECRET=SUPERCRET

# MySQL Root Password
MYSQL_ROOT_PASSWORD=SUPERCRET

# Logging
LOG_LEVEL=info

# CORS (Comma-separated URLs allowed to access API)
CORS_ORIGIN=http://localhost:3000,http://localhost:8080
